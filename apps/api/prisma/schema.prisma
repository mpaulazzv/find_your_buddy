generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PostStatus {
  AVAILABLE
  ADOPTED
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String?
  posts         Post[]
  phoneNumber   String?
  profileComplete Boolean        @default(false)
  subscriptions Subscription[]
  authTypes       AuthType[]
  sessions      Session[]
  phoneVerified Boolean @default(false)
  emailVerified DateTime?
}

model AuthType {
  id                 Int     @id @default(autoincrement())
  userId             Int
  type               String 
  provider           String  
  providerAccountId  String  
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique             
  userId       Int                         
  expires      DateTime                     
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Department {
  id     Int    @id @default(autoincrement())
  name   String @unique
  cities City[]
}

model City {
  id            Int            @id @default(autoincrement())
  departmentId  Int
  department    Department     @relation(fields: [departmentId], references: [id])
  name          String         @unique
  subscriptions Subscription[]
  posts         Post[]
}

model Species {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  subscriptions Subscription[]
  breeds        Breeds[]
}

model Breeds {
  id   Int    @id @default(autoincrement())
  name String @unique
  speciesId Int
  species   Species @relation(fields: [speciesId], references: [id])
  pets      Pet[]
}

model Pet {
  id          Int     @id @default(autoincrement())
  name        String
  breedId     Int
  breed       Breeds @relation(fields: [breedId], references: [id])
  gender      String
  posts       Post[]
  age         Int
}

model AgeCategory {
  id        Int    @id @default(autoincrement())
  name      String @unique
  minAge    Int
  maxAge    Int
  subscriptions Subscription[]
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  statusId    Int
  status      PostStatus @default(AVAILABLE)
  createdAt   DateTime @default(now())

  authorId Int
  author   User @relation(fields: [authorId], references: [id])

  petId  Int
  pet    Pet  @relation(fields: [petId], references: [id])
  cityId Int
  city   City @relation(fields: [cityId], references: [id])
  images  PostImage[]
}

model PostImage {
  id     Int    @id @default(autoincrement())
  url    String
  postId Int
  isMain Boolean @default(false)
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Subscription {
  id          Int     @id @default(autoincrement())
  userId      Int
  user        User    @relation(fields: [userId], references: [id])
  speciesId   Int?
  species     Species? @relation(fields: [speciesId], references: [id])
  cityId      Int?
  city        City?    @relation(fields: [cityId], references: [id])
  ageCategoryId Int?
  ageCategory AgeCategory? @relation(fields: [ageCategoryId], references: [id])

  @@unique([userId, speciesId, cityId, ageCategoryId])
}
